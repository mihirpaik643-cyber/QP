# Copy this file to ".env" (same folder) and paste your real key in.
# ".env" is listed in .gitignore, so GitHub will never see it.
#
# Once .env exists with a key, server.js loads it automatically when you
# run `node server.js` — the app's Profile screen will already show
# "API Key Connected" and Upload & Analyze works with no typing needed.

GEMINI_API_KEY=
